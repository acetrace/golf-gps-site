---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import StatCounter from './StatCounter.astro';

interface Stat {
  value: number;
  label: string;
  suffix?: string;
  prefix?: string;
  decimals?: number;
  format?: 'comma' | 'plain';
}

interface Props {
  id: string;
  kicker: string;
  title: string;
  body: string;
  screenshot: ImageMetadata;
  screenshotAlt: string;
  stats: Stat[];
  side: 'left' | 'right';
}

const { id, kicker, title, body, screenshot, screenshotAlt, stats, side } = Astro.props;

const phoneFirst = side === 'left';
---
<section id={id} class="relative py-28 lg:py-40 overflow-hidden">
  <div class="container max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      <div class={`lg:col-span-5 ${phoneFirst ? 'lg:order-1' : ''}`}>
        <div class="relative mx-auto max-w-[320px] lg:max-w-[360px]">
          <div
            class="absolute -inset-6 rounded-[3rem] bg-gold/5 blur-2xl"
            aria-hidden="true"
          ></div>
          <div class="relative rounded-[2.5rem] bg-dusk-700 p-3 ring-1 ring-gold/20 shadow-gold-glow">
            <Image
              src={screenshot}
              alt={screenshotAlt}
              widths={[320, 480, 720]}
              sizes="(min-width: 1024px) 360px, 320px"
              loading="lazy"
              decoding="async"
              format="webp"
              quality={80}
              class="w-full h-auto rounded-[2rem] block"
            />
          </div>
        </div>
      </div>

      <div class="lg:col-span-7 space-y-8">
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <span class="font-mono text-gold text-xs uppercase tracking-[0.3em]">{kicker}</span>
            <span class="h-px flex-1 max-w-[80px] bg-gold/30"></span>
          </div>
          <h2 class="font-display text-5xl md:text-6xl lg:text-7xl uppercase leading-[0.95] text-ink text-balance">
            {title}
          </h2>
          <p class="font-sans text-lg md:text-xl text-ink-muted max-w-xl leading-relaxed">
            {body}
          </p>
        </div>

        {stats.length > 0 && (
          <div class="grid grid-cols-2 gap-8 pt-4 max-w-md">
            {stats.map((s) => (
              <StatCounter
                value={s.value}
                label={s.label}
                suffix={s.suffix}
                prefix={s.prefix}
                decimals={s.decimals}
                format={s.format}
              />
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</section>
