---
interface Props {
  size?: 'default' | 'lg';
  align?: 'left' | 'center';
}

const { size = 'default', align = 'left' } = Astro.props;

const padding = size === 'lg' ? 'px-6 py-3.5' : 'px-5 py-3';
const iconSize = size === 'lg' ? 28 : 22;
const wrapperAlign = align === 'center' ? 'justify-center' : 'justify-start';
---
<div class={`flex flex-wrap gap-3 ${wrapperAlign}`}>
  <a
    href="#"
    aria-label="Download on the App Store"
    class={`group inline-flex items-center gap-3 ${padding} rounded-2xl bg-ink text-dusk transition-all duration-300 hover:bg-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold/50 focus-visible:ring-offset-2 focus-visible:ring-offset-dusk`}
  >
    <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.05 12.04c-.03-2.99 2.45-4.43 2.56-4.5-1.4-2.05-3.57-2.33-4.34-2.36-1.85-.19-3.6 1.09-4.54 1.09-.94 0-2.39-1.07-3.93-1.04-2.02.03-3.88 1.17-4.92 2.99-2.1 3.64-.54 9.02 1.5 11.96 1 1.44 2.19 3.06 3.76 3 1.51-.06 2.08-.98 3.91-.98 1.82 0 2.34.98 3.93.95 1.62-.03 2.65-1.47 3.64-2.92 1.15-1.67 1.62-3.3 1.65-3.39-.04-.02-3.17-1.22-3.22-4.8zM14.7 4.05c.82-1 1.38-2.39 1.23-3.78-1.19.05-2.63.79-3.48 1.79-.76.88-1.43 2.29-1.25 3.64 1.33.1 2.69-.67 3.5-1.65z"/>
    </svg>
    <div class="flex flex-col leading-none text-left">
      <span class="font-mono text-[9px] uppercase tracking-[0.18em] opacity-70">Download on</span>
      <span class="font-display text-base md:text-lg uppercase tracking-tight">App Store</span>
    </div>
  </a>

  <a
    href="#"
    aria-label="Get it on Google Play"
    class={`group inline-flex items-center gap-3 ${padding} rounded-2xl border-2 border-ink/20 bg-transparent text-ink transition-all duration-300 hover:border-gold hover:text-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold/50 focus-visible:ring-offset-2 focus-visible:ring-offset-dusk`}
  >
    <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M3.609 1.814 13.792 12 3.61 22.186a.5.5 0 0 1-.61-.486V2.3a.5.5 0 0 1 .609-.486zM14.5 12.707l2.515-2.515 3.43 1.962a.5.5 0 0 1 0 .867l-3.43 1.962L14.5 12.707zm-1-1.414L4.844 2.638l11.476 6.564L13.5 11.293zm0 1.414 2.82 2.82L4.843 21.362 13.5 12.707z"/>
    </svg>
    <div class="flex flex-col leading-none text-left">
      <span class="font-mono text-[9px] uppercase tracking-[0.18em] opacity-70">Get it on</span>
      <span class="font-display text-base md:text-lg uppercase tracking-tight">Google Play</span>
    </div>
  </a>
</div>
