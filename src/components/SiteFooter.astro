---
const currentYear = new Date().getFullYear();
const focusLink =
  'focus-visible:text-gold focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-gold/40 focus-visible:ring-offset-4 focus-visible:ring-offset-dusk rounded-sm';
---
<footer class="relative border-t border-gold/10 bg-dusk-900 pt-20 pb-10">
  <div class="container max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-16">
      <div class="md:col-span-5 space-y-5">
        <a href="/" class="flex flex-col leading-none">
          <span class="font-display text-3xl uppercase tracking-tight text-ink">Golf GPS</span>
          <span class="font-mono text-[10px] uppercase tracking-[0.25em] text-gold mt-1">Rangefinder</span>
        </a>
        <p class="font-sans text-sm text-ink-muted leading-relaxed max-w-sm">
          Precision distance tracking and course management for golfers of every level.
        </p>
      </div>

      <div class="md:col-span-3">
        <h4 class="font-mono text-[10px] uppercase tracking-[0.32em] text-gold mb-5">Product</h4>
        <ul class="space-y-3 font-sans text-sm text-ink-muted">
          <li><a href="/#scorecard" class={`hover:text-gold transition-colors ${focusLink}`}>Scorecard</a></li>
          <li><a href="/#shot-tracker" class={`hover:text-gold transition-colors ${focusLink}`}>Shot Tracker</a></li>
          <li><a href="/#courses" class={`hover:text-gold transition-colors ${focusLink}`}>Courses Nearby</a></li>
          <li><a href="/#stats" class={`hover:text-gold transition-colors ${focusLink}`}>Stats &amp; History</a></li>
        </ul>
      </div>

      <div class="md:col-span-4">
        <h4 class="font-mono text-[10px] uppercase tracking-[0.32em] text-gold mb-5">Legal</h4>
        <ul class="space-y-3 font-sans text-sm text-ink-muted">
          <li><a href="/privacy-policy/" class={`hover:text-gold transition-colors ${focusLink}`}>Privacy Policy</a></li>
          <li><a href="/terms-of-service/" class={`hover:text-gold transition-colors ${focusLink}`}>Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-gold/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-ink-dim">
        © {currentYear} Golf GPS · All rights reserved
      </p>
      <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-ink-dim">
        Made for the love of the game
      </p>
    </div>
  </div>
</footer>
